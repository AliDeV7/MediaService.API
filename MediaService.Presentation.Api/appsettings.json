{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "StorageRootPath": "wwwroot",
    "BaseUrl": ""
  },

  "ImageProcessing": {
    "ThumbnailWidth": 400,
    "WebPQuality": 80,
    "GenerateThumbnail": false,
    "ConvertToWebP": false,
    "MinThumbnailWidth": 50,
    "MaxThumbnailWidth": 2000,
    "MinQuality": 1,
    "MaxQuality": 100,
    "SupportedOutputFormats": [ "webp", "jpg", "jpeg", "png" ],
    "DefaultOutputFormat": "webp"
  },

  "ImageValidation": {
    "MaxFileSizeBytes": 10485760,
    "MinWidth": 50,
    "MaxWidth": 10000,
    "MinHeight": 50,
    "MaxHeight": 10000,
    "AllowedMimeTypes": [
      "image/jpeg",
      "image/jpg",
      "image/png",
      "image/webp",
      "image/gif",
      "image/bmp",
      "image/tiff"
    ],
    "AllowedExtensions": [ "jpg", "jpeg", "png", "webp", "gif", "bmp", "tiff", "tif" ],
    "MaxAspectRatio": 10.0,
    "MinAspectRatio": 0.1
  }
}
