{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "StorageRootPath": "wwwroot",
    "BaseUrl": ""
  },

  "ImageProcessing": {
    "ThumbnailWidth": 400,
    "WebPQuality": 80,
    "GenerateThumbnail": false,
    "ConvertToWebP": false,
    "MinThumbnailWidth": 50,
    "MaxThumbnailWidth": 2000,
    "MinQuality": 1,
    "MaxQuality": 100,
    "SupportedOutputFormats": [ "webp", "jpg", "jpeg", "png" ],
    "DefaultOutputFormat": "webp"
  },

  "MediaValidation": {
    "Image": {
      "MaxFileSizeBytes": 10485760,
      "MaxWidth": 8000,
      "MaxHeight": 8000,
      "MinWidth": 100,
      "MinHeight": 100
    }
  },

  "JwtSettings": {
    "SecretKey": "your-super-secret-key-must-be-at-least-32-characters-long!!",
    "Issuer": "MediaService",
    "Audience": "MediaServiceClients",
    "ExpirationMinutes": 60
  },

  "ServiceClients": [
    {
      "ClientId": "media-processor-service",
      "ClientSecret": "processor-secret-key-123",
      "Name": "Media Processor Service",
      "Role": "Service",
      "Permissions": [ "media:read", "media:write", "media:process" ],
      "IsActive": true
    },
    {
      "ClientId": "admin-dashboard",
      "ClientSecret": "admin-secret-key-456",
      "Name": "Admin Dashboard",
      "Role": "Admin",
      "Permissions": [ "media:read", "media:write", "media:delete", "client:manage" ],
      "IsActive": true
    }
  ]
}
