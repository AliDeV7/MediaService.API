{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "StorageRootPath": "wwwroot",
    "BaseUrl": ""
  },

  "ImageProcessing": {
    "ThumbnailWidth": 400,
    "WebPQuality": 100,
    "GenerateThumbnail": false,
    "ConvertToWebP": false,
    "MinThumbnailWidth": 50,
    "MaxThumbnailWidth": 2000,
    "MinQuality": 1,
    "MaxQuality": 100,
    "SupportedOutputFormats": [ "webp", "jpg", "jpeg", "png" ],
    "DefaultOutputFormat": "webp"
  },

  "MediaValidation": {
    "Image": {
      "MaxFileSizeBytes": 10485760,
      "MaxWidth": 8000,
      "MaxHeight": 8000,
      "MinWidth": 100,
      "MinHeight": 100
    }
  }
}
